---
CompileFlags:
  Add:
    - "-Wall"
    - "-Wextra"
    - "-Wpedantic"
    - "-Werror"
    - "-Wunused-using-decls"
    - "-Wunused-using-decls"
    - "-Wconst-qualifiers"

Diagnostics:
  # Warn using a symbol but haven't directly included its header (transitive includes)
  MissingIncludes: Strict

  # Warn when #include lines that you aren't actually using in the file
  UnusedIncludes: Strict

  # clang-tidy rules embedded directly into clangd
  ClangTidy:
    FastCheckFilter: None
    Add:
      - modernize-use-constexpr
      - readability-non-const-parameter
      - readability-const-return-type
      - misc-include-cleaner
      - misc-const-correctness
      - misc-throw-by-value-catch-by-reference
      - misc-unused-using-decl
      - modernize-*
      - performance-*
      - bugprone-*
    Remove:
      - modernize-use-trailing-return-type
    CheckOptions:
      misc-const-correctness.AllowedTypes: "std::scoped_lock;std::unique_lock;std::lock_guard"
...
